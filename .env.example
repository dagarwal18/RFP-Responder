# ═══════════════════════════════════════════════════════════
#  SECRETS & CONNECTION STRINGS ONLY
#  Model names, thresholds → config.py defaults
# ═══════════════════════════════════════════════════════════

# LLM (Groq Cloud) — multiple keys for round-robin (comma-separated)
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
# Or single key (fallback if GROQ_API_KEYS is empty):
# GROQ_API_KEY=gsk_your_groq_api_key_here

# VLM & Embeddings (HuggingFace Inference API)
HUGGINGFACE_API_KEYS=hf_key1,hf_key2,hf_key3
# Or single key (fallback if HUGGINGFACE_API_KEYS is empty):
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key_here

# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Pinecone Vector DB
PINECONE_API_KEY=pcsk_your_pinecone_api_key_here
